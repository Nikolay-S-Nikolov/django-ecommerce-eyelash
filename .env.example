# =====================================================================
# Lash Store — Environment variables
# Copy this file to `.env` and fill in your own values.
# =====================================================================

# ----- Django core -----
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated list WITH scheme. Required for HTTPS POST requests (CSRF) in Django 4.0+.
# Example: https://your-app.up.railway.app,https://www.lashstore.com
CSRF_TRUSTED_ORIGINS=

# ----- Database (PostgreSQL) -----
# Option A (PaaS — Railway / Render / Heroku): set DATABASE_URL and skip the DB_* vars below.
# DATABASE_URL=postgres://user:password@host:5432/dbname
#
# Option B (local dev): set discrete DB_* vars.
DB_NAME=lash_store
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# ----- Email (SMTP) -----
# For Gmail use an App Password (not your regular password).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your-smtp-app-password

# ----- Google OAuth (django-allauth) -----
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----- Allauth -----
# Set to "https" in production.
ACCOUNT_DEFAULT_HTTP_PROTOCOL=http

# ----- Cloudinary (media storage) -----
# Sign up at https://cloudinary.com and grab these from the Dashboard.
# Leave empty for local development to fall back to filesystem storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
